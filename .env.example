# Firebase Web App config — Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — only if you use Firebase Analytics
# VITE_FIREBASE_MEASUREMENT_ID=

# Desktop agent only (local .env — not needed on Vercel)
D7_AGENT_EMAIL=
D7_AGENT_PASSWORD=

# Public app URL (used in notification email links and link previews — set on Vercel too)
# No trailing slash, e.g. https://www.district7.co.uk
VITE_APP_URL=https://district7.co.uk

# Email + admin API (required for invite emails in dev AND production)
# Copy these to .env.local for local development (npm run dev loads them for /api routes).
# Set the same variables in Vercel → Project → Settings → Environment Variables.
#
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=District 7 <notifications@district7.co.uk>
#
# Firebase Admin — pick ONE option:
#   A) Local dev (recommended): save the downloaded key as .firebase-service-account.json (gitignored)
#      FIREBASE_SERVICE_ACCOUNT_FILE=.firebase-service-account.json
#   B) Vercel / single env var: paste minified one-line JSON (no line breaks)
#      FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
#
# Resend notes:
# - onboarding@resend.dev (default) only delivers to YOUR Resend account email (testing only).
# - For real invites: verify your domain at https://resend.com/domains and use RESEND_FROM_EMAIL on that domain.
