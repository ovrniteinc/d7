# Firebase Web App config — Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — only if you use Firebase Analytics
# VITE_FIREBASE_MEASUREMENT_ID=

# Desktop agent only (local .env — not needed on Vercel)
D7_AGENT_EMAIL=
D7_AGENT_PASSWORD=

# Public app URL (used in notification email links and link previews — set on Vercel too)
# No trailing slash, e.g. https://www.district7.co.uk
VITE_APP_URL=https://district7.co.uk

# Vercel serverless only (Project Settings → Environment Variables)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=District 7 <notifications@district7.co.uk>
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
